# Copy to `.env` for local dev.

# ---- App ----
APP_ENV=dev

# ---- API / Dashboard ----
API_BASE_URL=http://127.0.0.1:8000

# ---- CORS ----
# Comma-separated list of allowed origins for browsers.
# Example:
# CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
CORS_ORIGINS=

# ---- Database (Local) ----
# For Neon: use the provided connection string, typically with sslmode=require
# Example:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DB?sslmode=require
# Local example:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/hro_ps_ai
DATABASE_URL=

# ---- JWT ----
# CHANGE IN PRODUCTION
JWT_SECRET_KEY=dev-unsafe-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Artifacts ----
ARTIFACT_DIR=.

# ---- Tenancy ----
TENANT_MODE_ENABLED=true
DEFAULT_TENANT_SLUG=demo-hospital

# ---- SQLAlchemy pool tuning ----
SQLALCHEMY_ECHO=false
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=10
SQLALCHEMY_POOL_RECYCLE=1800
